# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=logistics_reporting
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=false
WAREHOUSE_UPLOAD_PATH=./uploads/warehouse
# Отдельный диск или сетевой том. Резервные копии также удаляются после выдачи ТС.
WAREHOUSE_PHOTO_BACKUP_PATH=./backups/warehouse-photos
WAREHOUSE_TUS_TEMP_PATH=./uploads/warehouse-tus-temp
WAREHOUSE_PENDING_UPLOAD_TTL_HOURS=24
WAREHOUSE_TUS_CLEANUP_MAX_AGE_HOURS=24
WAREHOUSE_TUS_CLEANUP_INTERVAL_HOURS=1

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d
DEFAULT_ADMIN_EMAIL=2720233@gmail.com
DEFAULT_ADMIN_PASSWORD=312046

# Redis
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@logistics.example.com

# App
NODE_ENV=development
APP_PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# File uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10mb

# Logging
LOG_LEVEL=info

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_USE_QUEUE=false
SCHEDULER_INTERVAL_MINUTES=5
SCHEDULER_TIMEZONE=Asia/Vladivostok

# Registration
INVITE_ONLY=true

# Proxy
TRUST_PROXY=1
